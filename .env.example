# WhatsApp del negocio (con código país, sin + ni espacios).
# Default actual (modo prueba): 525655867604 — José Alvarado.
# Línea oficial pendiente del dueño del negocio.
NEXT_PUBLIC_WHATSAPP_NUMBER=525655867604

# URL canónica del sitio (sin slash final)
NEXT_PUBLIC_SITE_URL=https://pandaalbercas.vercel.app

# Modo prueba (banner amarillo + sufijo [PRUEBA] en mensajes). "0" para apagar.
NEXT_PUBLIC_TEST_MODE=1

# ----------------------------------------------------------------------
# Supabase — persistencia de cotizaciones y /admin
# ----------------------------------------------------------------------
# Settings → API en supabase.com (o Lovable Cloud → Backend → API).
# Si dejas vacío, la app sigue funcionando pero NO guarda en DB.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role — solo server side. NUNCA en NEXT_PUBLIC_*.
SUPABASE_SERVICE_ROLE=
